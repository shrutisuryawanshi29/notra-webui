# Notra — Environment Variables
# Copy this to .env.local and fill in your values.
# For Vercel deployment, set these in Project Settings > Environment Variables.

# Notion Integration Token (optional on Vercel — set as env var in Vercel dashboard)
# If not set here, the token can be entered during the setup flow.
# WARNING: The token entered during setup is stored in localStorage (client-side).
# For production, set this as a Vercel environment variable so it stays server-side only.
# Find or create your token at: https://www.notion.so/my-integrations
NOTION_TOKEN=
